{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "**/media/**",
          "favicon.ico",
          "logo.svg"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/custom"
    ],
    "globalMetadata": {
      "_appName": "OnePayroll Learn",
      "_appTitle": "OnePayroll Learn",
      "_appLogoPath": "logo.svg",
      "_enableSearch": true,
      "pdf": false
    }
  }
}