{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "**/media/**",
          "favicon.ico",
          "logo.svg"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/custom"
    ],
    "globalMetadata": {
      "_appName": "OnePayroll Learn",
      "_appTitle": "OnePayroll Learn",
      "_appLogoPath": "logo.svg",
      "_appLogoUrl": "/",
      "_appFaviconPath": "favicon.ico",
      "_enableSearch": true,
      "_appFooter": "<span>Powered by <a href='https://onepayroll.com'>SwissSalary USA INC.</a> &mdash; Next-generation payroll for Business Central</span>",
      "_disableContribution": false,
      "pdf": false
    }
  }
}